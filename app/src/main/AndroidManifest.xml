<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Network & Location -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- osmdroid tile cache (only needed on API < 29, ignored on newer) -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!-- Notifications (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Exact alarms — required for the daily weather notification to fire on time -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />

    <!-- Reschedule alarm after device reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Required for the alarm full-screen intent to show on the lock screen (Android 11+) -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

    <!-- Vibration for the alarm -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Weather">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Weather">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Full-screen alarm screen shown on lock screen when alarm fires -->
        <activity
            android:name=".AlarmActivity"
            android:exported="false"
            android:showOnLockScreen="true"
            android:turnScreenOn="true"
            android:theme="@style/Theme.Weather" />

        <!-- Fires the daily weather notification at the exact scheduled time -->
        <receiver
            android:name=".data.local.worker.WeatherNotificationReceiver"
            android:exported="false" />

        <!-- Fires the daily weather alarm (with sound) at the exact scheduled time -->
        <receiver
            android:name=".data.local.worker.WeatherAlarmReceiver"
            android:exported="false" />

        <!-- Handles the Dismiss button on the alarm notification -->
        <receiver
            android:name=".data.local.worker.AlarmDismissReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.example.weather.ACTION_DISMISS_ALARM" />
            </intent-filter>
        </receiver>

        <!-- Restores the alarm after the device reboots (AlarmManager alarms don't survive reboots) -->
        <receiver
            android:name=".data.local.worker.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>